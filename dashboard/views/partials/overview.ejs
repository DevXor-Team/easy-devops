<!-- Dashboard Overview Page -->
<div v-show="page === 'overview'" class="w-full">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h2 class="text-2xl font-bold tracking-tight text-foreground">Overview</h2>
      <p class="text-muted font-medium text-sm mt-1">High-level status of your proxy infrastructure</p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <!-- Nginx Status Card -->
    <div class="stat-card group">
      <div class="flex items-start justify-between">
        <div>
          <p class="form-label">Nginx Process</p>
          <div class="mt-2 flex items-baseline gap-2">
            <h3 class="text-3xl font-bold tracking-tight text-foreground">
              {{ nginx.status?.running ? 'Active' : 'Offline' }}
            </h3>
          </div>
          <div class="mt-3 flex items-center gap-2">
            <div class="status-dot" :class="nginx.status?.running ? 'active' : 'inactive'"></div>
            <span class="text-xs font-mono font-medium text-muted">
              PID: {{ nginx.status?.pid || '---' }}
            </span>
          </div>
        </div>
        <div class="stat-icon">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
          </svg>
        </div>
      </div>
      <!-- Trendline overlay -->
      <div class="absolute bottom-0 left-0 right-0 h-12 opacity-10 pointer-events-none transition-opacity group-hover:opacity-20"
        style="background: linear-gradient(0deg, var(--color-primary) 0%, transparent 100%);"></div>
    </div>

    <!-- Domains Configured Card -->
    <div class="stat-card group">
      <div class="flex items-start justify-between">
        <div>
          <p class="form-label">Active Domains</p>
          <div class="mt-2 flex items-baseline gap-2">
            <h3 class="text-3xl font-bold tracking-tight text-foreground">
              {{ domains.list.filter(d => d.enabled !== false).length }}
            </h3>
            <span class="text-sm font-medium text-muted uppercase tracking-wider">/ {{ domains.list.length }}</span>
          </div>
          <div class="mt-3 flex items-center gap-1.5 text-xs text-muted font-medium">
            <svg class="w-3.5 h-3.5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
            <span class="text-primary">+{{ domains.list.filter(d => d.enabled !== false).length > 0 ? '100' : '0' }}%</span>
            <span>managed configs</span>
          </div>
        </div>
        <div class="stat-icon">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
          </svg>
        </div>
      </div>
      <!-- Trendline overlay -->
      <div class="absolute bottom-0 left-0 right-0 h-12 opacity-10 pointer-events-none transition-opacity group-hover:opacity-20"
        style="background: linear-gradient(0deg, var(--color-primary) 0%, transparent 100%);"></div>
    </div>

    <!-- SSL Certificates Card -->
    <div class="stat-card group">
      <div class="flex items-start justify-between">
        <div>
          <p class="form-label">SSL Certificates</p>
          <div class="mt-2 flex items-baseline gap-2">
            <h3 class="text-3xl font-bold tracking-tight text-foreground">
              {{ ssl.certs.length }}
            </h3>
          </div>
          <div class="mt-3 flex items-center gap-2 text-xs font-medium">
            <span v-if="expiringCount > 0" class="px-2.5 py-1 rounded-[6px] bg-amber-500/12 text-amber-500 border border-amber-500/25 font-bold">
              {{ expiringCount }} Expiring
            </span>
            <span v-else class="text-green-500 flex items-center gap-1.5 font-bold">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              All Healthy
            </span>
          </div>
        </div>
        <div class="stat-icon">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
      </div>
      <!-- Trendline overlay -->
      <div class="absolute bottom-0 left-0 right-0 h-12 opacity-10 pointer-events-none transition-opacity group-hover:opacity-20"
        style="background: linear-gradient(0deg, var(--color-primary) 0%, transparent 100%);"></div>
    </div>

    <!-- System Uptime Card -->
    <div class="stat-card group">
      <div class="flex items-start justify-between">
        <div>
          <p class="form-label">Service Engine</p>
          <div class="mt-2 flex items-baseline gap-2">
            <h3 class="text-3xl font-bold tracking-tight text-foreground font-mono" style="letter-spacing: -1px;">
              {{ nginx.status?.running ? '100%' : '0%' }}
            </h3>
          </div>
          <div class="mt-3 flex items-center gap-1.5 text-xs text-muted font-medium font-mono">
            Uptime: {{ nginx.status?.running ? 'Active' : 'Offline' }}
          </div>
        </div>
        <div class="stat-icon">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
      </div>
      <!-- Trendline overlay -->
      <div class="absolute bottom-0 left-0 right-0 h-12 opacity-10 pointer-events-none transition-opacity group-hover:opacity-20"
        style="background: linear-gradient(0deg, var(--color-primary) 0%, transparent 100%);"></div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="mt-10">
    <h3 class="text-[10px] uppercase font-bold text-muted tracking-widest mb-4">Quick Actions</h3>
    <div class="flex flex-wrap gap-4">
      <button @click="navigateTo('domains')" class="btn btn-primary">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        Add Domain
      </button>
      <button @click="navigateTo('ssl')" class="btn btn-secondary">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
        Issue SSL Let's Encrypt
      </button>
      <button @click="nginxAction('reload')" class="btn btn-secondary" :disabled="!nginx.status?.running">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
        Reload Nginx
      </button>
    </div>
  </div>
</div>
