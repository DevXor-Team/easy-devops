<!-- Nginx Page -->
<div v-show="page === 'nginx'" class="w-full">
<div class="flex items-center justify-between mb-8">
<div>
<h2 class="text-2xl font-bold tracking-tight text-foreground">Nginx</h2>
<p class="text-muted font-medium text-sm mt-1">Control, configure and monitor nginx</p>
</div>
<button @click="loadNginxStatus" class="btn btn-secondary">
<svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
</svg>
Refresh
</button>
</div>

<div class="flex flex-col gap-6 pb-12">
<!-- Status Bar -->
<div class="stat-card p-6 relative overflow-hidden">
<div class="absolute top-0 left-0 w-full h-1 bg-primary/40"></div>
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6">
<div class="flex items-center gap-4">
<div class="w-14 h-14 rounded-[16px] bg-background flex items-center justify-center shrink-0 border border-border relative shadow-sm">
<svg class="w-7 h-7 text-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" /></svg>
<div class="absolute -top-1.5 -right-1.5 w-4 h-4 rounded-full border-2 border-surface shadow-md" :class="nginx.status?.running ? 'bg-green-500' : 'bg-red-500'"></div>
</div>
<div>
<div class="text-lg font-bold text-foreground tracking-tight">{{ nginx.status?.running ? 'Running' : 'Stopped' }}</div>
<div class="text-[11px] font-mono text-muted font-bold mt-0.5">{{ nginx.status?.version || 'Unknown Version' }}</div>
</div>
</div>
<div class="flex flex-wrap gap-2">
<button v-if="!nginx.status?.running" @click="nginxAction('start')" class="btn btn-primary min-w-[90px]">
<svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
Start
</button>
<template v-else>
<button @click="nginxAction('reload')" class="btn btn-secondary">Reload</button>
<button @click="nginxAction('restart')" class="btn btn-secondary opacity-50 cursor-not-allowed" disabled>Restart</button>
<button @click="nginxAction('stop')" class="btn btn-danger">Stop</button>
</template>
<!-- Separator -->
<div class="w-px h-8 border-l border-border mx-1 self-center hidden sm:block"></div>
<button @click="nginxAction('test')" class="btn btn-secondary">Test Config</button>
</div>
</div>

<div v-if="nginx.actionMsg" class="mt-4 p-4 rounded-[12px] bg-primary/10 border border-primary/20 text-primary text-[13px] font-mono inline-block w-full">
{{ nginx.actionMsg }}
</div>
<div v-if="nginx.actionError" class="mt-4 p-4 rounded-[12px] bg-red-500/10 border border-red-500/20 text-red-500 text-[13px] font-mono break-all inline-block w-full">
{{ nginx.actionError }}
</div>
</div>

<!-- Config Editor -->
<div class="stat-card flex flex-col overflow-hidden">
<div class="flex flex-col sm:flex-row sm:items-center justify-between p-5 border-b border-border bg-black/5 dark:bg-white/5 gap-4">
<h3 class="form-label !mb-0 font-bold">Config Editor</h3>
<div class="flex gap-3">
<select v-model="nginx.selectedConfig" @change="selectConfig(nginx.selectedConfig)" class="form-input !py-1.5 !px-3 font-mono text-[12px] min-w-[200px]">
<option value="" disabled>Select Conf File...</option>
<option v-for="c in nginx.configs" :key="c" :value="c">{{ c }}</option>
</select>
<button @click="saveNginxConfig" :disabled="!nginx.selectedConfig || nginx.configSaving" class="btn btn-primary min-w-[80px]">
<svg v-if="nginx.configSaving" class="w-3 h-3 animate-spin mr-1.5 inline-block" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
{{ nginx.configSaving ? 'Wait...' : 'Save' }}
</button>
</div>
</div>
<div class="relative w-full p-0 flex flex-col">
<!-- syntax-like dark block for config -->
<textarea v-model="nginx.configContent" :disabled="!nginx.selectedConfig" rows="18"
class="w-full bg-[#0a0f18] text-[#a5d6ff] font-mono text-[13px] leading-relaxed p-6 focus:outline-none focus:bg-[#0d1421] transition-colors disabled:opacity-50 disabled:bg-[#0a0f18] resize-y rounded-b-[20px]"
placeholder="Select a config file to start editing..."></textarea>

<!-- Copy Button (hover) -->
<button v-if="nginx.configContent && nginx.selectedConfig"
@click="navigator.clipboard.writeText(nginx.configContent)"
class="absolute top-4 right-6 btn btn-secondary btn-icon text-muted border-white/10 hover:text-white hover:bg-white/10 opacity-0 hover:opacity-100 transition-opacity"
title="Copy to clipboard"
onmouseover="this.style.opacity='1'"
onmouseout="this.style.opacity=''"
id="copyConfBtn">
<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
</button>
<style>
textarea:hover + #copyConfBtn, #copyConfBtn:hover { opacity: 1; }
</style>
</div>
<div v-if="nginx.configMsg" class="p-3 border-t border-border font-mono text-[11px] flex items-center justify-between font-bold" :class="nginx.configMsg.includes('pass') ? 'bg-primary/5 text-primary' : 'bg-red-500/5 text-red-500'">
<span>{{ nginx.configMsg }}</span>
</div>
</div>

<!-- Error Log -->
<div class="stat-card overflow-hidden">
<div class="flex items-center justify-between p-5 border-b border-border bg-black/5 dark:bg-white/5">
<h3 class="form-label !mb-0 font-bold">Error Log</h3>
<button @click="loadNginxLogs" class="btn btn-secondary btn-sm">
<svg class="w-3.5 h-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
</svg>
Refresh
</button>
</div>
<div class="w-full bg-[#0a0f18] text-[#e2e8f0] font-mono text-[12px] leading-relaxed p-5 h-64 overflow-y-auto whitespace-pre-wrap rounded-b-[20px] relative">
<!-- Copy Button for Logs -->
<button v-if="nginx.logs.length > 0"
@click="navigator.clipboard.writeText(nginx.logs.join('\n'))"
class="absolute top-3 right-4 btn btn-secondary btn-sm text-white bg-white/10 hover:bg-white/20 border-transparent opacity-0 transition-opacity"
title="Copy Logs"
onmouseover="this.style.opacity='1'"
onmouseout="this.style.opacity=''"
id="copyLogBtn">
Copy Lines
</button>
<style>
.bg-\[\#0a0f18\]:hover #copyLogBtn, #copyLogBtn:hover { opacity: 1; }
</style>

<div v-if="nginx.logsLoading" class="text-muted flex items-center gap-2">
<svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
Loading...
</div>
<div v-else-if="nginx.logs.length === 0" class="text-muted italic">No errors logged currently.</div>
<div v-else v-for="(line, idx) in nginx.logs" :key="idx" class="border-b border-white/5 py-1.5 last:border-0 hover:bg-white/5 px-2 -mx-2 rounded transition-colors break-words">
{{ line }}
</div>
</div>
</div>
</div>
</div>
